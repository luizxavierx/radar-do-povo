APP_NAME="API Radar do Povo"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8081
APP_PORT=8081
APP_HOST=0.0.0.0
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info
LOG_FORMATTER=json

DB_CONNECTION=pgsql
DB_HOST=radardopovo.cv2iu4y4oqkv.us-east-2.rds.amazonaws.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=radardopovo
DB_PASSWORD=radardopovo
# aliases opcionais se quiser manter naming antigo:
# DB_NAME=postgres
# DB_USER=radardopovo
# DB_PASS=radardopovo
DB_SSLMODE=verify-full
DB_SSL_ROOT_CERT=/certs/global-bundle.pem

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=changeme
REDIS_PORT=26739
REDIS_DB=0
REDIS_CACHE_DB=1

CACHE_STORE=redis
QUEUE_CONNECTION=sync

RADAR_QUERY_CACHE_TTL_SECONDS=300
RADAR_EXTERNAL_CACHE_TTL_SECONDS=1800
RADAR_HTTP_TIMEOUT_SECONDS=1
RADAR_HTTP_RETRY_TIMES=1
RADAR_HTTP_RETRY_SLEEP_MS=100
RADAR_MAX_PAGE_SIZE=20
RADAR_MAX_NESTED_PAGE_SIZE=10
RADAR_SLOW_QUERY_LOG_MS=200
RADAR_ENABLE_VIAGENS_TOKEN_FALLBACK=false
GRAPHQL_MAX_COMPLEXITY=220
GRAPHQL_MAX_DEPTH=12

SENADO_BASE_URL=https://legis.senado.leg.br/dadosabertos
TSE_PORTAL_BASE_URL=https://dadosabertos.tse.jus.br
TSE_CANDIDATOS_CDN_BASE_URL=https://cdn.tse.jus.br/estatistica/sead/odsele/consulta_cand
TSE_DIVULGACANDCONTAS_URL=https://divulgacandcontas.tse.jus.br
LEXML_SEARCH_URL=https://www.lexml.gov.br/busca/search
LEXML_SRU_URL=
BRASILIO_BASE_URL=https://brasil.io
BRASILIO_TOKEN=
BRASILIO_ELEICOES_DATASET_PATH=/api/dataset/eleicoes-brasil/candidatos/data/
