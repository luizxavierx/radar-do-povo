# Base unica da API Radar do Povo
# Producao:
RADAR_API_BASE=https://api.radardopovo.com
RADAR_API_KEY=troque-esta-chave

# Local / VPS:
# RADAR_API_BASE=http://127.0.0.1:8081
# RADAR_API_KEY=troque-esta-chave

# Tambem aceita com /graphql no final:
# RADAR_API_BASE=https://api.radardopovo.com/graphql
# RADAR_API_BASE=http://127.0.0.1:8081/graphql

# Area de membros
VITE_MEMBER_API_BASE_URL=https://abertos.radardopovo.com/v1

# Google Identity Services
# VITE_GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# Checkout PIX no front:
# O endpoint real deve ser server-side para nao expor o token da PushinPay.
# Se nao estiver pronto, mantenha o mock ligado para validar a UX.
VITE_MEMBER_PIX_MOCK=true
# VITE_MEMBER_PIX_ENDPOINT=https://radardopovo.com/api/member/billing/pix
