# Recomendado na VPS: mesmo dominio do site, com Apache fazendo proxy interno.
# A chave compartilhada do backend nao deve ser empacotada no navegador.
RADAR_API_BASE=/graphql

# Desenvolvimento local com Vite proxyando para o backend Laravel.
# Esses valores ficam no servidor de desenvolvimento, nao no bundle publico.
# RADAR_PROXY_TARGET=http://127.0.0.1:8081
# RADAR_SHARED_API_KEY=troque-esta-chave

# Exemplo de base absoluta sem embutir segredo no browser:
# RADAR_API_BASE=https://radardopovo.com/graphql

# Exemplo local:
# RADAR_API_BASE=/graphql
